# ── VibeFlow Environment Variables ──────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub — this file (.env.example) is safe to commit.

# Supabase (get from supabase.com → your project → settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (get from dashboard.stripe.com → developers → API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create in Stripe → products → add product)
NEXT_PUBLIC_STRIPE_LAUNCH_PRICE_ID=
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=

# Anthropic (get from console.anthropic.com → API keys)
ANTHROPIC_API_KEY=

# PostHog product analytics (get from posthog.com → project settings → API keys)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google OAuth for GA4 integration (get from console.cloud.google.com → credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption key for OAuth tokens at rest. Generate with: openssl rand -hex 32
# If rotated, all stored OAuth tokens become unreadable — users must reconnect.
ENCRYPTION_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
